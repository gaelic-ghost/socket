{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "sh ${PLUGIN_ROOT}/hooks/capture-session-start.sh",
            "statusMessage": "Running Codex Utilities SessionStart hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
