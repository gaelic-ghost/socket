{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "sh ${PLUGIN_ROOT}/hooks/run-thread-title-hook.sh",
            "statusMessage": "Running AgentDeck SessionStart hook",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ${PLUGIN_ROOT}/hooks/run-thread-title-hook.sh",
            "statusMessage": "Running AgentDeck Stop hook",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ${PLUGIN_ROOT}/hooks/run-thread-title-hook.sh",
            "statusMessage": "Logging AgentDeck tool-use hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
